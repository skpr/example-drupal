@@ -0,0 +1,127 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\search_api_opensearch_semantic\Plugin\views\area;
+
+use Drupal\Component\Utility\Html;
+use Drupal\Component\Utility\Xss;
+use Drupal\Core\Form\FormStateInterface;
+use Drupal\Core\Render\RendererInterface;
+use Drupal\views\Attribute\ViewsArea;
+use Drupal\views\Plugin\views\area\AreaPluginBase;
+use Symfony\Component\DependencyInjection\ContainerInterface;
+
+/**
+ * Views area handler to display some configurable result summary.
+ *
+ * @ingroup views_area_handlers
+ */
+#[ViewsArea(id: self::PLUGIN_ID)]
+class AiSummary extends AreaPluginBase {
+
+  public const string PLUGIN_ID = 'ai_summary';
+
+  /**
+   * {@inheritdoc}
+   *
+   * @phpstan-ignore-next-line
+   */
+  public static function create(ContainerInterface $container, array $configuration, $plugin_id, $plugin_definition): static {
+    /** @var static $plugin */
+    $plugin = parent::create($container, $configuration, $plugin_id, $plugin_definition);
+    $plugin->setRenderer($container->get('renderer'));
+    return $plugin;
+  }
+
+  /**
+   * Sets the renderer service.
+   */
+  public function setRenderer(RendererInterface $renderer): static {
+    $this->renderer = $renderer;
+    return $this;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function defineOptions(): array {
+    $options = parent::defineOptions();
+    $options['rag_result_summary'] = ['default' => ''];
+    $options['title'] = ['default' => '✨ AI generated summary'];
+    return $options;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  // @phpstan-ignore-next-line
+  public function buildOptionsForm(&$form, FormStateInterface $form_state): void {
+    $form['title'] = [
+      '#type' => 'textfield',
+      '#title' => $this->t('AI Summary title'),
+      '#description' => $this->t('This title will be displayed on AI summary results.'),
+      '#default_value' => $this->options['title'],
+      '#required' => TRUE,
+    ];
+    parent::buildOptionsForm($form, $form_state);
+  }
+
+  /**
+   * {@inheritdoc}
+   *
+   * @phpstan-ignore missingType.iterableValue
+   */
+  public function render($empty = FALSE): array {
+    // @see \Drupal\search_api_opensearch_semantic\Plugin\views\Query\SemanticSearchQuery::execute()
+    if ($this->view->result === [] || $this->options['rag_result_summary'] === '') {
+      return [];
+    }
+    $answer = [
+      '#type' => '#markup',
+      '#markup' => $this->filterResponse($this->options['rag_result_summary']['answer']),
+    ];
+    return [
+      '#type' => 'inline_template',
+      '#template' => '<div class="search-api-ai-summary"><h4>{{ title }}</h4>{{ summary }}</div>',
+      '#context' => [
+        'title' => $this->options['title'],
+        'summary' => $this->renderer->renderInIsolation($answer),
+      ],
+    ];
+  }
+
+  /**
+   * Applies Drupal filters and strips/corrects data coming from AI.
+   */
+  public function filterResponse(?string $text): string {
+    if ($text === NULL) {
+      return '';
+    }
+    // Decode the text so if AI returns encoded text, we can display correct
+    // values.
+    $text = Html::decodeEntities($text);
+    $text = Xss::filter($text, [
+      'a',
+      'b',
+      'h1',
+      'h2',
+      'h3',
+      'h4',
+      'h5',
+      'h6',
+      'li',
+      'ol',
+      'p',
+      'strong',
+      'sub',
+      'sup',
+      'ul',
+    ]);
+    // Despite decoding entities, there are still some entities left.
+    // For now, we are replacing it with empty string. Even if we pass
+    // instructions to LLM, it still ignores it.
+    return \str_replace(['&lt;', '&gt;'], '', $text);
+  }
+
+}
