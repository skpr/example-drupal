index 0000000000000000000000000000000000000000..5868af4e1c2f1bb236ebd9e499e9d50c818a10c7
--- /dev/null
+++ b/src/EventSubscriber/ViewsPluginInitializeEventSubscriber.php
@@ -0,0 +1,40 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\search_api_opensearch_semantic\EventSubscriber;
+
+use Drupal\search_api_opensearch_semantic\Event\ViewsPluginInitializeEvent;
+use Drupal\search_api_opensearch_semantic\Plugin\views\area\AiSummary;
+use Symfony\Component\EventDispatcher\EventSubscriberInterface;
+
+/**
+ * Subscribes to ViewsPluginInitialize to update views area plugin.
+ */
+class ViewsPluginInitializeEventSubscriber implements EventSubscriberInterface {
+
+  /**
+   * Set the RAG result summary to the header's area plugin.
+   */
+  public function initializeViewsPlugin(ViewsPluginInitializeEvent $event): void {
+    $view = $event->getView();
+    $results = $event->getResults();
+    if (!array_key_exists(AiSummary::PLUGIN_ID, $view->header)) {
+      return;
+    }
+    if (!array_key_exists('retrieval_augmented_generation', $results->getExtraData('opensearch_response')['ext'] ?? [])) {
+      return;
+    }
+    $view->header[AiSummary::PLUGIN_ID]->options['rag_result_summary'] = $results->getExtraData('opensearch_response')['ext']['retrieval_augmented_generation'];
+  }
+
+  /**
+   * {@inheritdoc}
+   */
