--- /dev/null
+++ b/src/Event/ViewsPluginInitializeEvent.php
@@ -0,0 +1,38 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\search_api_opensearch_semantic\Event;
+
+use Drupal\search_api\Query\ResultSetInterface;
+use Drupal\views\ViewExecutable;
+
+/**
+ * Event fired after view's ViewsExecutable is initialized.
+ *
+ * This event allows altering view's header, footer handler plugin.
+ *
+ * @see \Drupal\search_api_opensearch_semantic\Plugin\views\query\SemanticSearchQuery::execute()
+ */
+class ViewsPluginInitializeEvent {
+
+  public function __construct(
+    protected ResultSetInterface $result,
+    protected ViewExecutable $view,
+  ) {}
+
+  /**
+   * Get the results.
+   */
+  public function getResults(): ResultSetInterface {
+    return $this->result;
+  }
+
+  /**
+   * Get the index.
+   */
+  public function getView(): ViewExecutable {
+    return $this->view;
+  }
+
+}
diff --git a/src/EventSubscriber/HybridSearchQueryEventSubscriber.php b/src/EventSubscriber/HybridSearchQueryEventSubscriber.php
new file mode 100644
index 0000000000000000000000000000000000000000..953159b9ee5f16a3dd93d5f1cbd1f9139c2e38c3
--- /dev/null
+++ b/src/EventSubscriber/HybridSearchQueryEventSubscriber.php
@@ -0,0 +1,65 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\search_api_opensearch_semantic\EventSubscriber;
+
+use Drupal\search_api_opensearch\Event\QueryParamsEvent;
+use Drupal\search_api_opensearch_semantic\Enum\SearchTypeEnum;
+use Symfony\Component\EventDispatcher\EventSubscriberInterface;
+
+/**
+ * Restructures hybrid search query into valid OpenSearch hybrid query format.
+ *
+ * The core QueryParamBuilder wraps all search params inside query.bool.must,
+ * but OpenSearch requires the hybrid query at the top level of "query".
+ * Filters must also be moved to "post_filter" for hybrid queries.
+ *
+ * @see https://docs.opensearch.org/latest/query-dsl/compound/hybrid/#limitations
+ */
+class HybridSearchQueryEventSubscriber implements EventSubscriberInterface {
+
+  /**
+   * Restructures hybrid query params into valid OpenSearch format.
+   */
+  public function onQueryParamsBuild(QueryParamsEvent $event): void {
+    // Only act on hybrid search type queries.
+    if ($event->getQuery()->getOption('search_type') !== SearchTypeEnum::Hybrid) {
+      return;
+    }
+
+    $params = $event->getParams();
+
+    // Only act when hybrid is nested inside query.bool.must.
+    // This is an invalid search for hybrid queries.
+    if (empty($params['body']['query']['bool']['must']['hybrid'])) {
+      return;
+    }
+
+    $hybridQuery = $params['body']['query']['bool']['must']['hybrid'];
+    $filters = $params['body']['query']['bool']['filter'] ?? NULL;
+
+    // Move hybrid to top-level query.
+    $params['body']['query'] = ['hybrid' => $hybridQuery];
+
+    // Move filters to post_filter (filters can't be siblings of hybrid).
+    if ($filters !== NULL) {
+      $params['body']['post_filter'] = $filters;
+    }
+
+    $event->setParams($params);
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public static function getSubscribedEvents(): array {
+    return [
+      // Priority -100 ensures this runs after all other QueryParamsEvent
+      // subscribers (e.g. QueryParamsEventSubscriber adds min_score and
+      // search_pipeline, RAGQueryParamsEventSubscriber adds ext params).
+      QueryParamsEvent::class => ['onQueryParamsBuild', -100],
+    ];
+  }
+
+}
