       $params['body']['min_score'] = $event->getQuery()->getOption('min_score') ?? 0;
     }

-    // Pass search pipeline if search is hybrid search.
-    if (($pipeline = $event->getQuery()->getIndex()->getThirdPartySetting('search_api_opensearch_semantic', 'search_pipeline')) !== NULL) {
+    // Pass search pipeline if search is hybrid search and key is present.
+    //
+    // On pages like the search_api index landing page, we don't have the key.
+    // In such cases, we don't need to pass pipeline because a search
+    // query to know the "Server index status" doesn't need a pipeline.\
+    //
+    // In RAG search if we pass search_pipeline without key, it throws error.
+    $keys = $event->getQuery()->getOriginalKeys();
+    if (($pipeline = $event->getQuery()->getIndex()->getThirdPartySetting('search_api_opensearch_semantic', 'search_pipeline')) !== NULL && $keys !== NULL) {
       $params['search_pipeline'] = $pipeline;
     }
     $event->setParams($params);
diff --git a/src/EventSubscriber/RAGQueryParamsEventSubscriber.php b/src/EventSubscriber/RAGQueryParamsEventSubscriber.php
new file mode 100644
index 0000000000000000000000000000000000000000..271884ebbe2411bd432f93dc5f3c8aee3a082423
--- /dev/null
+++ b/src/EventSubscriber/RAGQueryParamsEventSubscriber.php
@@ -0,0 +1,52 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\search_api_opensearch_semantic\EventSubscriber;
+
+use Drupal\search_api_opensearch\Event\QueryParamsEvent;
+use Drupal\search_api_opensearch_semantic\Trait\SemanticIndexTrait;
+use Symfony\Component\EventDispatcher\EventSubscriberInterface;
+
+/**
+ * Subscribes to QueryParamsEvent to add RAG queries.
+ */
+class RAGQueryParamsEventSubscriber implements EventSubscriberInterface {
+
+  use SemanticIndexTrait;
+
+  /**
+   * Adds min_score value if it is semantic search index.
+   */
+  public function onQueryParamsBuild(QueryParamsEvent $event): void {
+    if ($this->isRagEnabled($event->getQuery()->getIndex()->id()) === FALSE) {
+      return;
+    }
+    $params = $event->getParams();
+    $settings = $event->getQuery()->getIndex()->getThirdPartySettings('search_api_opensearch_semantic');
+    $keys = $event->getQuery()->getOriginalKeys();
+    if ($keys === NULL) {
+      return;
+    }
+    assert(\is_string($keys));
+    // Build Param for RAG.
+    $params['body']['ext'] = [
+      'generative_qa_parameters' => [
+        'llm_model' => $settings['rag']['rag_llm_model'],
+        'llm_question' => $keys,
+        'context_size' => 5,
+      ],
+    ];
+    $event->setParams($params);
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public static function getSubscribedEvents(): array {
+    return [
+      QueryParamsEvent::class => ['onQueryParamsBuild'],
+    ];
+  }
+
+}
